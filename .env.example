# ==========================================
# 📅 日程管家 (Schedule Butler) - 极简初始配置导航
# 
# 欢迎使用！请将此文件复制并重命名为 `.env`，然后填入以下信息。
# 填好后，双击 start.bat (Windows) 或运行 bash start.sh (Mac/Linux) 即可启动。
# ==========================================

# ------------------------------------------
# 1. 大模型配置 (必填)
# 用于让机器人能听懂人话，从你的消息里提取时间和事项。
# 推荐使用 Kimi (Moonshot)，注册免费送 Token。
# ------------------------------------------
KIMI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ------------------------------------------
# 2. 个性化配置
# ------------------------------------------
# 你的名字（让 AI 更像是一对一服务专属管家）
USER_NAME="主人"
# 所在时区（决定日程提醒的时间基准，国内填 Asia/Shanghai，海外填对应时区如 America/New_York）
TIMEZONE="Asia/Shanghai"

# ------------------------------------------
# 3. 机器人渠道选择 (必填其一)
# 告诉系统你准备在哪接收提醒：
# 可选值：telegram 或者 feishu
# ------------------------------------------
ACTIVE_BOT="telegram"


# ------------------------------------------
# 4. Telegram 配置 (如果上面选择了 telegram，则必填)
# ------------------------------------------
# 从 BotFather 获取的 Token
TELEGRAM_BOT_TOKEN="123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ"
# 海外代理设置 (大陆用户必填，如果在海外服务器运行请留空)
# 例如: http://127.0.0.1:7890
HTTP_PROXY=""
HTTPS_PROXY=""

# ------------------------------------------
# 5. 飞书配置 (如果上面选择了 feishu，则必填)
# ------------------------------------------
FEISHU_APP_ID="cli_xxxxxxxxxxxx"
FEISHU_APP_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
